{
    "name": "nowo-tech/select-all-choice-bundle",
    "description": "Symfony bundle that adds a 'Select all' checkbox for ChoiceType fields with multiple=true (expanded or select).",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "symfony",
        "symfony-bundle",
        "form",
        "choice",
        "select-all",
        "multiple",
        "stimulus",
        "vite"
    ],
    "homepage": "https://github.com/nowo-tech/SelectAllChoiceBundle",
    "support": {
        "issues": "https://github.com/nowo-tech/SelectAllChoiceBundle/issues",
        "source": "https://github.com/nowo-tech/SelectAllChoiceBundle"
    },
    "authors": [
        {
            "name": "Nowo.tech",
            "homepage": "https://nowo.tech"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/config": "^7.0 || ^8.0",
        "symfony/dependency-injection": "^7.0 || ^8.0",
        "symfony/form": "^7.0 || ^8.0",
        "symfony/framework-bundle": "^7.0 || ^8.0",
        "symfony/http-kernel": "^7.0 || ^8.0",
        "symfony/translation": "^7.0 || ^8.0",
        "symfony/twig-bundle": "^7.0 || ^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^10.0",
        "rector/rector": "^2.0",
        "symfony/yaml": "^7.0 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Nowo\\SelectAllChoiceBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nowo\\SelectAllChoiceBundle\\Tests\\": "tests/"
        }
    },
    "archive": {
        "exclude": ["/demo", "/.cursor"]
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-text --coverage-html=coverage --coverage-clover=coverage.xml",
        "rector": "rector process",
        "rector-dry": "rector process --dry-run --no-progress-bar",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "update": "composer update --no-interaction",
        "validate": "composer validate --strict",
        "qa": ["@cs-check", "@test"]
    },
    "scripts-descriptions": {
        "cs-check": "Check code style with PHP-CS-Fixer",
        "cs-fix": "Fix code style with PHP-CS-Fixer",
        "test": "Run PHPUnit tests",
        "test-coverage": "Run PHPUnit tests with code coverage",
        "rector": "Apply Rector refactoring",
        "rector-dry": "Run Rector in dry-run mode",
        "phpstan": "Run PHPStan static analysis",
        "update": "Update composer.lock",
        "validate": "Validate composer.json (composer validate --strict)",
        "qa": "Run all quality assurance checks"
    }
}
