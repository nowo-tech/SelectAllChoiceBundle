# PHPStan configuration for SelectAllChoiceBundle.
#
# Static analysis on src/ and tests/ (level 8). PHP 8.2+ and Symfony 7|8.
# Run: make phpstan
parameters:
    level: 8
    paths:
        - src
        - tests
    excludePaths:
        - demo/*
        - vendor/*
    reportUnmatchedIgnoredErrors: false
    treatPhpDocTypesAsCertain: false
