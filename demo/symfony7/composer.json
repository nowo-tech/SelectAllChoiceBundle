{
    "name": "nowo-tech/select-all-choice-demo-symfony7",
    "description": "Demo for SelectAllChoiceBundle - Symfony 7",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "nowo-tech/select-all-choice-bundle": "@dev",
        "symfony/asset": "^7.0",
        "symfony/console": "^7.0",
        "symfony/dotenv": "^7.0",
        "symfony/form": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/http-kernel": "^7.0",
        "symfony/runtime": "^7.0",
        "symfony/twig-bundle": "^7.0",
        "symfony/validator": "^7.0",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "nowo-tech/twig-inspector-bundle": "v1.0.3",
        "symfony/debug-bundle": "^7.0",
        "symfony/web-profiler-bundle": "^7.0"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "@php bin/console cache:clear"
        },
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.0.*"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "/var/select-all-choice-bundle",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "dev"
}
