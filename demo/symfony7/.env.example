# Demo environment template. Copy to .env and adjust local values.

# APP_ENV: Symfony environment.
APP_ENV=dev

# APP_DEBUG: Enable debug mode in development.
APP_DEBUG=1

# APP_SECRET: Local secret used by Symfony; do not commit real secrets.
APP_SECRET=change_this_secret_key_to_a_random_value

# PORT: Host port exposed by docker-compose for this demo.
PORT=8007

# DEFAULT_URI: Default URL to open this demo in the browser.
DEFAULT_URI=http://localhost:8007
